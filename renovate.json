{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "dependencies"
  ],
  "timezone": "Europe/Berlin",
  "gitIgnoredAuthors": [
    "41898282+github-actions[bot]@users.noreply.github.com"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions"
    },
    {
      "matchDepTypes": [
        "aqua-package"
      ],
      "groupName": "aqua packages"
    },
    {
      "matchDepTypes": [
        "aqua-package"
      ],
      "ignoreUnstable": true,
      "allowedVersions": "!/[-.](?:alpha|beta|dev|rc)[0-9A-Za-z.-]*/i"
    },
    {
      "matchDepTypes": [
        "yazi-package"
      ],
      "groupName": "yazi packages"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update aqua standard registry ref in aqua.yaml",
      "managerFilePatterns": [
        "/^dot_config\\/aquaproj-aqua\\/aqua\\.yaml$/"
      ],
      "matchStrings": [
        "ref:\\s*(?<currentValue>v[0-9][^\\s#]*)\\s*#\\s*renovate:\\s*depName=(?<depName>[^\\s]+)"
      ],
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "description": "Update aqua package versions in aqua.yaml",
      "managerFilePatterns": [
        "/^dot_config\\/aquaproj-aqua\\/aqua\\.yaml$/"
      ],
      "matchStrings": [
        "-\\s+name:\\s*(?<fullName>(?<packageName>[^/\\s@#]+/[^/\\s@#]+)(?:/[^@\\s#]+)?)@(?<currentValue>(?:v|[0-9]|jq-|kustomize/)[^\\s#]*)"
      ],
      "depNameTemplate": "{{{fullName}}}",
      "depTypeTemplate": "aqua-package",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": "Update ble.sh release tag in ble.yaml",
      "managerFilePatterns": [
        "/^\\.chezmoidata\\/ble\\.yaml$/"
      ],
      "matchStrings": [
        "tag:\\s*(?<currentValue>v[0-9][^\\s#]*)\\s*#\\s*renovate:\\s*depName=(?<depName>[^\\s]+)"
      ],
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "description": "Update Yazi multi-plugin repo revisions in package.toml",
      "managerFilePatterns": [
        "/^dot_config\\/yazi\\/package\\.toml\\.tmpl$/"
      ],
      "matchStrings": [
        "\\[\\[(?:plugin|flavor)\\.deps\\]\\]\\s+use\\s*=\\s*\"(?<depName>[^\"/:]+/[^\"/:]+):[^\"]+\"\\s+rev\\s*=\\s*\"(?<currentDigest>[0-9a-f]{7,40})\""
      ],
      "currentValueTemplate": "main",
      "depTypeTemplate": "yazi-package",
      "packageNameTemplate": "https://github.com/{{{depName}}}",
      "datasourceTemplate": "git-refs"
    },
    {
      "customType": "regex",
      "description": "Update Yazi single-plugin repo revisions in package.toml",
      "managerFilePatterns": [
        "/^dot_config\\/yazi\\/package\\.toml\\.tmpl$/"
      ],
      "matchStrings": [
        "\\[\\[(?:plugin|flavor)\\.deps\\]\\]\\s+use\\s*=\\s*\"(?<depName>[^\"/:]+/[^\"/:]+)\"\\s+rev\\s*=\\s*\"(?<currentDigest>[0-9a-f]{7,40})\""
      ],
      "currentValueTemplate": "main",
      "depTypeTemplate": "yazi-package",
      "packageNameTemplate": "https://github.com/{{{depName}}}.yazi",
      "datasourceTemplate": "git-refs"
    }
  ]
}
