{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "dependencies"
  ],
  "timezone": "Europe/Berlin",
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update aqua standard registry ref in aqua.yaml",
      "managerFilePatterns": [
        "^dot_config/aquaproj-aqua/aqua\\.yaml$"
      ],
      "matchStrings": [
        "ref:\\s*(?<currentValue>v[0-9][^\\s#]*)\\s*#\\s*renovate:\\s*depName=(?<depName>[^\\s]+)"
      ],
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "description": "Update ble.sh release tag in ble.yaml",
      "managerFilePatterns": [
        "^\\.chezmoidata/ble\\.yaml$"
      ],
      "matchStrings": [
        "tag:\\s*(?<currentValue>v[0-9][^\\s#]*)\\s*#\\s*renovate:\\s*depName=(?<depName>[^\\s]+)"
      ],
      "datasourceTemplate": "github-tags"
    }
  ]
}
