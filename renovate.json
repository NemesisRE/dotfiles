{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "dependencies"
  ],
  "timezone": "Europe/Berlin",
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions"
    },
    {
      "matchDepTypes": [
        "yazi-package"
      ],
      "groupName": "yazi packages"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update aqua standard registry ref in aqua.yaml",
      "managerFilePatterns": [
        "^dot_config/aquaproj-aqua/aqua\\.yaml$"
      ],
      "matchStrings": [
        "ref:\\s*(?<currentValue>v[0-9][^\\s#]*)\\s*#\\s*renovate:\\s*depName=(?<depName>[^\\s]+)"
      ],
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "description": "Update ble.sh release tag in ble.yaml",
      "managerFilePatterns": [
        "^\\.chezmoidata/ble\\.yaml$"
      ],
      "matchStrings": [
        "tag:\\s*(?<currentValue>v[0-9][^\\s#]*)\\s*#\\s*renovate:\\s*depName=(?<depName>[^\\s]+)"
      ],
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "description": "Update Yazi package revisions in package.toml",
      "managerFilePatterns": [
        "^dot_config/yazi/package\\.toml\\.tmpl$"
      ],
      "matchStrings": [
        "\\[\\[(?:plugin|flavor)\\.deps\\]\\]\\s+use\\s*=\\s*\"(?<depName>[^\"/:]+/[^\"/:]+)(?::[^\"]+)?\"\\s+rev\\s*=\\s*\"(?<currentDigest>[0-9a-f]{7,40})\""
      ],
      "currentValueTemplate": "HEAD",
      "depTypeTemplate": "yazi-package",
      "packageNameTemplate": "https://github.com/{{{depName}}}",
      "datasourceTemplate": "git-refs"
    }
  ]
}
