#!/usr/bin/env bash
set -euo pipefail

print_header() {
  printf "\n== %s ==\n" "$1"
}

expand_path() {
  # expand ~ and return absolute path
  local p="$1"
  if [[ "$p" == ~* ]]; then
    printf "%s" "${p/#~/$HOME}"
  else
    printf "%s" "$p"
  fi
}

prompt_nonempty() {
  local var
  while true; do
    read -r -p "$1" var
    if [[ -n "$var" ]]; then
      printf "%s" "$var" && return 0
    fi
    printf "Please provide a value.\n"
  done
}

print_header "Git identity setup"

NAME=$(prompt_nonempty "Full name (user.name): ")
EMAIL=$(prompt_nonempty "Email (user.email): ")

read -r -p "Signing key (GPG ID or path to SSH key). Prefix with 'ssh:' to force SSH mode. Leave empty to skip: " SIGNKEY_RAW

SIGNKEY=""
SIGNKEY_SSH=false

if [[ -n "$SIGNKEY_RAW" ]]; then
  if [[ "$SIGNKEY_RAW" == ssh:* ]]; then
    SIGNKEY_SSH=true
    SIGNKEY="${SIGNKEY_RAW#ssh:}"
  else
    # If looks like a path or lives in ~/.ssh, treat as SSH key
    if [[ "$SIGNKEY_RAW" == /* || "$SIGNKEY_RAW" == ~* || "$SIGNKEY_RAW" == ./* || "$SIGNKEY_RAW" == ../* ]]; then
      P=$(expand_path "$SIGNKEY_RAW")
      if [[ -f "$P" || -f "$P.pub" ]]; then
        SIGNKEY_SSH=true
        SIGNKEY="$P"
      else
        SIGNKEY="$SIGNKEY_RAW"
      fi
    elif [[ "$SIGNKEY_RAW" == ssh-* || "$SIGNKEY_RAW" == ecdsa-* || "$SIGNKEY_RAW" == ed25519-* ]]; then
      # Looks like an SSH public key string
      SIGNKEY_SSH=true
      SIGNKEY="$SIGNKEY_RAW"
    else
      SIGNKEY="$SIGNKEY_RAW"
    fi
  fi
fi

# Apply git config
git config --global user.name "$NAME"
git config --global user.email "$EMAIL"

if [[ -n "$SIGNKEY" ]]; then
  git config --global user.signingkey "$SIGNKEY"
  git config --global commit.gpgsign true
  if [[ "$SIGNKEY_SSH" == true ]]; then
    git config --global gpg.format ssh
    printf "Set signing key as SSH. Configured gpg.format=ssh\n"
  else
    # assume openpgp for non-ssh
    git config --global gpg.format openpgp
    printf "Set signing key as OpenPGP. Configured gpg.format=openpgp\n"
  fi
else
  # No signing key provided — ensure commit.gpgsign is unset
  git config --global --unset commit.gpgsign 2>/dev/null || true
  printf "No signing key set; commit.gpgsign unset.\n"
fi

print_header "Resulting git config"
git config --global --get user.name || true
git config --global --get user.email || true
git config --global --get user.signingkey || true
git config --global --get gpg.format || true

LOCAL_CHEZMOI_CONFIG_DIR="${XDG_CONFIG_HOME:-${HOME}/.config}/chezmoi"
LOCAL_DATA_FILE="${LOCAL_CHEZMOI_CONFIG_DIR}/nredf-local.env"

if [[ -f "${LOCAL_DATA_FILE}" ]]; then
  # shellcheck disable=SC1090
  source "${LOCAL_DATA_FILE}"
fi

unset -v \
  NREDF_LOCAL__GIT__NAME \
  NREDF_LOCAL__GIT__EMAIL \
  NREDF_LOCAL__GIT__SIGNINGKEY \
  NREDF_LOCAL__GIT__SIGNINGKEY_SSH || true

if [[ -z "${SIGNKEY}" ]]; then
  NREDF_LOCAL__GITCONFIG__USER__SIGNINGKEY="__NREDF_EMPTY__"
else
  NREDF_LOCAL__GITCONFIG__USER__SIGNINGKEY="${SIGNKEY}"
fi

NREDF_LOCAL__GITCONFIG__USER__NAME="${NAME}"
NREDF_LOCAL__GITCONFIG__USER__EMAIL="${EMAIL}"
if [[ "${SIGNKEY_SSH}" == true ]]; then
  NREDF_LOCAL__GITCONFIG__GPG__FORMAT="ssh"
else
  NREDF_LOCAL__GITCONFIG__GPG__FORMAT="openpgp"
fi

mkdir -p "${LOCAL_CHEZMOI_CONFIG_DIR}"
tmp_local_data="$(mktemp "${LOCAL_CHEZMOI_CONFIG_DIR}/nredf-local.env.XXXXXX")"

{
  printf "# Machine-local chezmoi values generated by setup_git_identity.sh\n"
  while IFS= read -r var_name; do
    printf "%s=%q\n" "${var_name}" "${!var_name}"
  done < <(compgen -A variable NREDF_LOCAL__ | LC_ALL=C sort)
} > "${tmp_local_data}"

chmod 600 "${tmp_local_data}"
mv "${tmp_local_data}" "${LOCAL_DATA_FILE}"

printf "\nWrote local chezmoi identity data to %s\n" "${LOCAL_DATA_FILE}"
printf "Run 'chezmoi apply' to render managed config with these values.\n"

printf "\nDone.\n"
