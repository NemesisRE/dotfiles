#!/usr/bin/env bash
set -euo pipefail

print_header() {
  printf "\n== %s ==\n" "$1"
}

expand_path() {
  # expand ~ and return absolute path
  local p="$1"
  if [[ "$p" == ~* ]]; then
    printf "%s" "${p/#~/$HOME}"
  else
    printf "%s" "$p"
  fi
}

prompt_nonempty() {
  local var
  while true; do
    read -r -p "$1" var
    if [[ -n "$var" ]]; then
      printf "%s" "$var" && return 0
    fi
    printf "Please provide a value.\n"
  done
}

print_header "Git identity setup"

NAME=$(prompt_nonempty "Full name (user.name): ")
EMAIL=$(prompt_nonempty "Email (user.email): ")

read -r -p "Signing key (GPG ID or path to SSH key). Prefix with 'ssh:' to force SSH mode. Leave empty to skip: " SIGNKEY_RAW

SIGNKEY=""
SIGNKEY_SSH=false

if [[ -n "$SIGNKEY_RAW" ]]; then
  if [[ "$SIGNKEY_RAW" == ssh:* ]]; then
    SIGNKEY_SSH=true
    SIGNKEY="${SIGNKEY_RAW#ssh:}"
  else
    # If looks like a path or lives in ~/.ssh, treat as SSH key
    if [[ "$SIGNKEY_RAW" == /* || "$SIGNKEY_RAW" == ~* || "$SIGNKEY_RAW" == ./* || "$SIGNKEY_RAW" == ../* ]]; then
      P=$(expand_path "$SIGNKEY_RAW")
      if [[ -f "$P" || -f "$P.pub" ]]; then
        SIGNKEY_SSH=true
        SIGNKEY="$P"
      else
        SIGNKEY="$SIGNKEY_RAW"
      fi
    elif [[ "$SIGNKEY_RAW" == ssh-* || "$SIGNKEY_RAW" == ecdsa-* || "$SIGNKEY_RAW" == ed25519-* ]]; then
      # Looks like an SSH public key string
      SIGNKEY_SSH=true
      SIGNKEY="$SIGNKEY_RAW"
    else
      SIGNKEY="$SIGNKEY_RAW"
    fi
  fi
fi

# Apply git config
git config --global user.name "$NAME"
git config --global user.email "$EMAIL"

if [[ -n "$SIGNKEY" ]]; then
  git config --global user.signingkey "$SIGNKEY"
  git config --global commit.gpgsign true
  if [[ "$SIGNKEY_SSH" == true ]]; then
    git config --global gpg.format ssh
    printf "Set signing key as SSH. Configured gpg.format=ssh\n"
  else
    # assume openpgp for non-ssh
    git config --global gpg.format openpgp
    printf "Set signing key as OpenPGP. Configured gpg.format=openpgp\n"
  fi
else
  # No signing key provided — ensure commit.gpgsign is unset
  git config --global --unset commit.gpgsign 2>/dev/null || true
  printf "No signing key set; commit.gpgsign unset.\n"
fi

print_header "Resulting git config"
git config --global --get user.name || true
git config --global --get user.email || true
git config --global --get user.signingkey || true
git config --global --get gpg.format || true

find_chezmoi_repo() {
  # Try chezmoi CLI helpers first
  if command -v chezmoi >/dev/null 2>&1; then
    # try common subcommands that may return the source dir
    for cmd in "chezmoi source-path" "chezmoi source"; do
      out=$(eval "$cmd" 2>/dev/null || true)
      if [[ -n "$out" && -d "$out" ]]; then
        # if it contains a data/ directory, accept it
        if [[ -d "$out/data" ]]; then
          printf "%s" "$out"
          return 0
        fi
      fi
    done
  fi

  # Common locations
  candidates=("${HOME}/Repos/chezmoi" "${HOME}/chezmoi" "${HOME}/.local/share/chezmoi" "${HOME}/.config/chezmoi")
  for c in "${candidates[@]}"; do
    if [[ -d "$c" && -d "$c/data" ]]; then
      printf "%s" "$c"
      return 0
    fi
  done

  # Try a shallow search for a directory named 'chezmoi' under home (fast)
  repo=$(find "$HOME" -maxdepth 3 -type d -name "chezmoi" -print -quit 2>/dev/null || true)
  if [[ -n "$repo" && -d "$repo/data" ]]; then
    printf "%s" "$repo"
    return 0
  fi

  return 1
}

# Persist values to chezmoi data/git.yaml if we can find the source repo
if repo_root=$(find_chezmoi_repo); then
  datafile="$repo_root/data/git.yaml"
  mkdir -p "$(dirname "$datafile")"
  cat > "$datafile" <<YAML
# Generated by setup_git_identity.sh — edit with chezmoi
git:
  name: "${NAME}"
  email: "${EMAIL}"
  signingkey: "${SIGNKEY}"
  signingkey_ssh: ${SIGNKEY_SSH}
YAML
  printf "\nWrote identity to %s\n" "$datafile"
  printf "Run 'chezmoi apply' in %s to apply to your home directory.\n" "$repo_root"
else
  printf "\nCould not locate a chezmoi source repo to persist data/git.yaml.\n"
  printf "Add the following YAML to your chezmoi data/git.yaml manually:\n\n"
  cat <<YAML
git:
  name: "${NAME}"
  email: "${EMAIL}"
  signingkey: "${SIGNKEY}"
  signingkey_ssh: ${SIGNKEY_SSH}
YAML
fi

printf "\nDone.\n"
