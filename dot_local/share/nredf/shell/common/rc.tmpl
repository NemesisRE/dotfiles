#!/usr/bin/env bash
#
# vim: ts=2 sw=2 et ff=unix ft=bash syntax=sh
#
# chezmoi-managed common shell rc — sourced by .bashrc / .zshrc / .zprofile / .bash_profile
# No homesick/homeshick references. All paths are relative to ${HOME}.

NREDF_COMMON_RC_PROFILE="${NREDF_COMMON_RC_PROFILE:-full}"

# Standard 24h throttle interval for all daily operations
NREDF_24H_INTERVAL=86400

# Load all common function files
for NREDF_FUNCTIONS in "${NREDF_DOT_PATH}/shell/common/functions/"*; do
  # shellcheck disable=SC1090
  source "${NREDF_FUNCTIONS}"
done

# Initialize startup profiling (no-op unless NREDF_PROFILE_STARTUP=1 via `reload -p`)
_nredf_profile_init
_nredf_step "source common functions"

_nredf_get_sys_info
_nredf_step "_nredf_get_sys_info"

if [[ -z "${NREDF_COMMON_DEFAULTS_DONE}" ]]; then
  _nredf_set_defaults
  _nredf_step "_nredf_set_defaults"
  if [[ "${NREDF_OS}" == "macos" ]]; then
    _nredf_macos_prerquisites
  fi

  # Update dotfiles from remote (throttled to once per 24h, no-op if chezmoi not found)
  [[ -z ${SUDO_COMMAND} && "${NREDF_COMMON_RC_PROFILE}" == "full" ]] && _nredf_chezmoi_update
  _nredf_step "_nredf_chezmoi_update"

  # config.bash is generated by chezmoi from .chezmoidata/nredf.yaml — source directly
  if [[ -e "${NREDF_CONFIG}/config.bash" ]]; then
    # shellcheck disable=SC1090
    source "${NREDF_CONFIG}/config.bash"
  fi
  _nredf_step "source config.bash"
  _nredf_set_local
  _nredf_step "_nredf_set_local"
  NREDF_COMMON_DEFAULTS_DONE="true"
fi

# Ensure aqua config env is always present, even if defaults were already marked done.
_nredf_set_aqua_env
_nredf_set_aqua_path
_nredf_step "_nredf_set_aqua_env/path"

# Run on each shell init so child/login shells always inherit a valid SSH_AUTH_SOCK.
_nredf_set_ssh_agent
_nredf_step "_nredf_set_ssh_agent"

if [[ "${NREDF_COMMON_RC_PROFILE}" == "login-minimal" ]]; then
  if command -v fnm &>/dev/null; then
    eval "$(fnm env --use-on-cd)"
  fi
  _nredf_step "fnm env (login-minimal)"
  return
fi

if [[ "${NREDF_COMMON_RC_PROFILE}" == "interactive-minimal" ]]; then
  echo -e "\033[1mCustomizing Shell\033[0m"
  # shellcheck disable=SC1090
  source "${NREDF_RC_PATH}/rc"
  _nredf_step "source rc (interactive-minimal)"
  _nredf_os_specific
  _nredf_set_local true
  _nredf_step "_nredf_set_local aliases (interactive-minimal)"
  if command -v atuin &>/dev/null; then
    eval "$(atuin init "${NREDF_SHELL_NAME}")"
  fi
  _nredf_step "atuin init (interactive-minimal)"
  return
fi

if [[ -z ${SUDO_COMMAND} ]]; then
  # Ensure aqua-managed command links exist (link-only, no eager downloads) — throttled 24h
  if command -v aqua &>/dev/null && ! _nredf_last_run "_nredf_aqua_ensure"; then
    aqua install -a -l >/dev/null 2>&1 || true
    _nredf_last_run "_nredf_aqua_ensure" "true" "$(($(date +%s) + NREDF_24H_INTERVAL))"
  fi
  _nredf_step "aqua install -a -l"
fi

# Shell-specific customization
echo -e "\033[1mCustomizing Shell\033[0m"
# shellcheck disable=SC1090
source "${NREDF_RC_PATH}/rc"
if [[ "${NREDF_SHELL_NAME}" != "zsh" ]]; then
  _nredf_step "source rc"
fi

_nredf_os_specific
_nredf_step "_nredf_os_specific"
_nredf_set_local true
_nredf_step "_nredf_set_local aliases"

# Atuin init — cache shell completion evaluation for 24h
if command -v atuin &>/dev/null && ! _nredf_last_run "_nredf_atuin_init"; then
  eval "$(atuin init "${NREDF_SHELL_NAME}")"
  _nredf_last_run "_nredf_atuin_init" "true" "$(($(date +%s) + NREDF_24H_INTERVAL))"
fi
_nredf_step "atuin init"

# FNM env — cache env evaluation for 24h
if command -v fnm &>/dev/null && ! _nredf_last_run "_nredf_fnm_env"; then
  eval "$(fnm env --use-on-cd)"
  _nredf_last_run "_nredf_fnm_env" "true" "$(($(date +%s) + NREDF_24H_INTERVAL))"
fi
_nredf_step "fnm env"

_nredf_remote_multiplexer
_nredf_step "_nredf_remote_multiplexer"
