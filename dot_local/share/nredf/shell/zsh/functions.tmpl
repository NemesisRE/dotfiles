#!/usr/bin/env bash
# chezmoi-managed: sheldon plugin loader for zsh
# This replaces the legacy `_nredf_zplug` with a sheldon-aware implementation.

function _nredf_load_p10k_early() {
  local p10k_theme="${XDG_DATA_HOME:-${HOME}/.local/share}/sheldon/repos/github.com/romkatv/powerlevel10k/powerlevel10k.zsh-theme"

  # Hybrid mode: load prompt theme now, keep the rest of plugins lazy.
  if [[ -f "${p10k_theme}" ]]; then
    source "${p10k_theme}"
  fi
  if [[ -f ~/.p10k.zsh ]]; then
    source ~/.p10k.zsh
    if (( ${+functions[p10k]} )); then
      p10k reload >/dev/null 2>&1 || true
    fi
  fi
}

function _nredf_load_sheldon_plugins() {
  # Initialize completion before plugin load if compdef is still unavailable.
  if (( ! ${+functions[compdef]} )); then
    autoload -Uz compinit
    compinit -i
  fi
  eval "$(sheldon source)"

  # Re-apply prompt config after full plugin load to keep p10k in sync.
  if (( ${+functions[_nredf_load_p10k_early]} )); then
    _nredf_load_p10k_early
  fi
}

function _nredf_zplug() {
  local sheldon_conf="${XDG_CONFIG_HOME:-${HOME}/.config}/sheldon/plugins.toml"

  # If no sheldon config present, nothing to do here.
  if [[ ! -f "${sheldon_conf}" ]]; then
    return 0
  fi

  if command -v sheldon >/dev/null 2>&1; then
    # Some plugins register completions at load time via compdef.
    if (( ! ${+functions[compdef]} )); then
      autoload -Uz compinit
      compinit -i
    fi

    # Load plugins: sheldon source outputs eval-able shell code.
    eval "$(sheldon source)"

    # Install/verify plugins in the background when the lock file is stale.
    # `sheldon lock` is idempotent and non-interactive.
    if [[ -z "${SUDO_COMMAND}" ]]; then
      sheldon lock >/dev/null 2>&1 || true
    fi
  else
    # sheldon not installed — do not error the shell. User should install sheldon.
    :
  fi
}
