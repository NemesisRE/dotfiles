## license:  MIT
## upstream: https://github.com/VictorPLopes/OneDark-Pro-Kitty-Terminal/blob/main/kitty-themes/OneDark-Pro.conf
## blurb:    Kitty theme inspired by Binaryify's One Dark Pro theme for Visual Studio Code.

# Colors

# The basic colors
foreground              #ABB2BF
background              #282C34
selection_foreground    #282C34
selection_background    #ABB2BF

# Cursor colors
cursor                  #ABB2BF
cursor_text_color       #282C34

# URL underline color when hovering with mouse
url_color               #ABB2BF

tab_bar_background           #21252b
active_tab_foreground        #282c34
active_tab_background        #61afef
active_tab_font_style        bold
inactive_tab_foreground      #abb2bf
inactive_tab_background      #3e4452
inactive_tab_font_style      normal
tab_bar_margin_color         none
tab_bar_min_tabs             1
tab_bar_edge                 bottom
tab_bar_style                powerline
tab_powerline_style          angled
background_opacity           0.95
dynamic_background_opacity   yes
tab_title_template           "{index}: {title}"

# The 16 terminal colors

# black
color0 #3F4451
color8 #4F5666

# red
color1 #E06C75
color9 #BE5046

