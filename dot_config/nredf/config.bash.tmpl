# Generated by chezmoi from .chezmoidata/nredf.yaml — do not edit manually.
{{- $g := .generell }}
{{- $ssh := index $g "ssh-agent" | default "default" }}
NREDF_MULTIPLEXER="{{ if index $g "multiplexer" }}true{{ else }}false{{ end }}"
NREDF_AGENT_PIPE="{{ if eq $ssh "pipe" }}true{{ else }}false{{ end }}"
NREDF_AGENT_GPG="{{ if eq $ssh "gpg" }}true{{ else }}false{{ end }}"
NREDF_AGENT_BITWARDEN="{{ if eq $ssh "bitwarden" }}true{{ else }}false{{ end }}"
{{- range $k, $v := .other }}
{{- $outkey := $k | upper | replace "-" "_" | replace "." "_" }}
NREDF_{{ $outkey }}="{{ $v }}"
{{- end }}
