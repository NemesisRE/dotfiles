# Generated by chezmoi — do not edit by hand
[user]
{{- if .git.name }}
  name = "{{ .git.name }}"
{{- end }}
{{- if .git.email }}
  email = "{{ .git.email }}"
{{- end }}
{{- if .git.signingkey }}
  signingkey = "{{ .git.signingkey }}"
{{- end }}

[commit]
  gpgsign = {{ if .git.signingkey }}true{{ else }}false{{ end }}

{{- if .git.signingkey }}
{{- if .git.signingkey_ssh }}
[gpg]
  format = ssh
{{- else }}
[gpg]
  format = openpgp
{{- end }}
{{- end }}

[core]
  editor = vim

[init]
  defaultBranch = main

[push]
  default = simple
  followTags = true

[pull]
  rebase = true

[rebase]
  autoStash = true

[tag]
  sort = version:refname

[color "status"]
	added = green bold
	changed = yellow bold
	untracked = red bold

[format]
	pretty = format:%C(blue)%ad%Creset %C(yellow)%h%C(green)%d%Creset %C(blue)%s %C(magenta) [%an]%Creset

[alias]
	# Basic Commands
	co = checkout
	ci = commit -m
	st = status --ignored=traditional --show-stash --short
	mt = mergeTool
	df = diffTool
	ba = branch
	baa = branch -a
	pr = pull --rebase
	cp = cherry-pick
	aa = add -A
	fa = fetch -p --all
	rc = rebase --continue
	pullsub = "!f(){ git submodule sync; git submodule update --init --remote --recursive; }; f"
	pullall = "!f(){ git pull \"$@\"; git submodule update --init --remote --recursive; }; f"
  gone = "!f() { git fetch --prune && git branch -vv | grep \": gone]" | awk "{print \\\"$1\\\"}" | xargs -r git branch -d; }; f"
	# Log aliases
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(cyan)- %an%Creset' --abbrev-commit --date=relative
	lstat = log --stat --relative --abbrev-commit --date=local --pretty=format:'%C(white)%h %C(cyan)%cr %C(green)by %cn %Creset%C(yellow)%n%s%Creset'

[credential]
	helper = cache --timeout=3600
