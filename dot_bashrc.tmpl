# chezmoi-managed .bashrc
# Sets required env and sources common rc (if present)

# If not running interactively, don't do anything
[ -z "${PS1}" ] && return

for NREDF_BREW_BASH in /opt/homebrew/bin/bash /usr/local/bin/bash; do
  if [[ -x "${NREDF_BREW_BASH}" ]]; then
    NREDF_BREW_BASH_DIR="${NREDF_BREW_BASH%/bash}"
    if [[ "${PATH%%:*}" != "${NREDF_BREW_BASH_DIR}" ]]; then
      export PATH="${NREDF_BREW_BASH_DIR}:${PATH}"
      hash -r 2>/dev/null || true
    fi
    if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 4) )) && [[ "${BASH:-}" != "${NREDF_BREW_BASH}" ]]; then
      exec "${NREDF_BREW_BASH}" -i
    fi
    break
  fi
done

export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-${HOME}/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}"
export SHELL="${BASH:-${SHELL:-/bin/bash}}"

if ! command -v _nredf_step >/dev/null 2>&1; then
  _nredf_step() { :; }
fi

export NREDF_SHELL_NAME="bash"
export NREDF_DOT_PATH="${NREDF_DOT_PATH:-${XDG_DATA_HOME}/nredf}"
if [[ ! -f "${NREDF_DOT_PATH}/shell/common/rc" && -f "${XDG_DATA_HOME}/nredf/shell/common/rc" ]]; then
  export NREDF_DOT_PATH="${XDG_DATA_HOME}/nredf"
fi
export NREDF_RC_PATH="${NREDF_DOT_PATH}/shell/${NREDF_SHELL_NAME}"
export NREDF_COMMON_RC_PROFILE="${NREDF_COMMON_RC_PROFILE:-full}"

if [[ -f "${XDG_DATA_HOME}/blesh/ble.sh" ]]; then
  # ble.sh should be sourced near the top of .bashrc and attached at the end.
  source -- "${XDG_DATA_HOME}/blesh/ble.sh" --attach=none
fi

# Source common rc if present
if [[ -f "${NREDF_DOT_PATH}/shell/common/rc" ]]; then
  source "${NREDF_DOT_PATH}/shell/common/rc"
fi
_nredf_step "source common/rc"

# Optional post-common bits (safe-guarded)
if command -v _nredf_tool_fzf_source &>/dev/null; then
  _nredf_tool_fzf_source
fi
_nredf_step "fzf source"

if command -v __atuin_history &>/dev/null; then
  if [[ -n "${BLE_VERSION-}" ]] && command -v ble-bind &>/dev/null; then
    ble-bind -x 'C-r' __atuin_history
  else
    bind -x '"\C-r": __atuin_history'
  fi
fi

if declare -F _nredf_init_kitty_shell_integration >/dev/null 2>&1; then
  _nredf_init_kitty_shell_integration
fi

if [[ -n "${BLE_VERSION-}" ]]; then
  ble-attach
  _nredf_step "ble attach"
fi
